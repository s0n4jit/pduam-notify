# ── EMAIL DELIVERY (SMTP / Gmail) ──────────────────────────────────────────
# Used by Next.js (email verification) and GitHub Actions (notice broadcasts)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
CUSTOM_FROM_EMAIL=notifications@yourdomain.com
REPLY_TO_EMAIL=contact@yourdomain.com

# ── GOOGLE SHEETS INTEGRATION ──────────────────────────────────────────────
# Used by Next.js (subscriber writes) and GitHub Actions (subscriber reads)
GOOGLE_SHEET_ID=your-spreadsheet-id
GOOGLE_SERVICE_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# ── TELEGRAM BROADCAST ──────────────────────────────────────────────────────
# Used by GitHub Actions (channel broadcasts)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHANNEL_ID=@pduam_notices

# ── SECURITY / CRYPTO ───────────────────────────────────────────────────────
# Shared across Next.js and GitHub Actions for secure token/unsubscribe links
HASH_SALT=your-48-byte-random-salt-here

# ── PRIVATE WORKER API INTEGRATION ──────────────────────────────────────────
# Used by Next.js and GitHub Actions to securely query scraped notices
API_URL=https://api.yourdomain.com
API_SECRET_KEY=your-api-secret-key-here

# ── WEB APPLICATION CONFIG ──────────────────────────────────────────────────
# Used by Next.js client-side/server-side redirects and URL generation
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

