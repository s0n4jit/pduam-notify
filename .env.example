# ─── Gmail SMTP ─────────────────────────────────────────────
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Custom Email Identity ──────────────────────────────────
# Display "from" address (Gmail sends on behalf of this)
CUSTOM_FROM_EMAIL=notifications@yourdomain.com
# Where replies go (can be different from sender)
REPLY_TO_EMAIL=contact@yourdomain.com

# ─── Google Sheets ──────────────────────────────────────────
GOOGLE_SHEET_ID=your-spreadsheet-id
GOOGLE_SERVICE_JSON={"type":"service_account",...}

# ─── App Config ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ─── Security ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
HASH_SALT=your-48-byte-random-salt-here

# ─── Telegram Bot (Optional) ────────────────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Channel ID: use @username format or numeric ID
# The bot must be added as an admin to the channel
TELEGRAM_CHANNEL_ID=@pduam_notices

# ─── API Security & URL ──────────────────────────────────────
API_SECRET_KEY=your-api-secret-key-here
API_URL=https://api.yourdomain.com

